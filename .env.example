MSG_BUFFER_SIZE=1024000
LOG_LEVEL=debug

INFLUX_HOST="http://localhost:8181"
INFLUX_TOKEN="apiv3_v..."
INFLUX_DATABASE=can_data
INFLUX_MAX_WRITE_LINES=2500
INFLUX_FLUSH_TIME=100
INFLUX_MAX_CONNECTIONS=30

MQTT_HOST=localhost:1883
MQTT_CLIENT_ID=bb_app
MQTT_TOPIC=bb_app
MQTT_QOS=0
MQTT_SHADOW_COPY=false
MQTT_DEDUPE=true
MQTT_DEDUPE_TIMEOUT_MS=1000
MQTT_DEDUPE_IDS=1,2,3

CSV_OUTPUT_FILE="./output.csv"
CSV_OUTPUT_HEADERS=true

# SIM_RATE: emit interval in nanoseconds (ns). Default 10ms = 10000000 ns.
SIM_RATE=1

INTERFACE_0_NAME="CAN C"
INTERFACE_0_SIM=true
INTERFACE_0_NET=sim
INTERFACE_0_URI=can0

INTERFACE_1_NAME="CAN IHS"
INTERFACE_1_SIM=true
INTERFACE_1_NET=sim
INTERFACE_1_URI=can1

INTERFACE_2_NAME="CAN LOW"
INTERFACE_2_SIM=true
INTERFACE_2_NET=sim
INTERFACE_2_URI=can2
